  "keyFeatures": [
    "Multi-tenant school management with tenant isolation",
    "Enrollment management with document upload to R2",
    "Student profiles with guardian relationships",
    "Academic tracking (subjects, grades, attendance, study plans)",
    "Discipline case management with due process workflow",
    "Circular broadcast communications system",
    "Role-based access control (RBAC) with 7 roles",
    "SIMAT export for Colombian regulatory compliance",
    "Supabase authentication with JWT validation",
    "Habeas Data compliance (Ley 1581/2012)"
  ],
  "publicApiSurface": [
    "POST /auth/me - Get authenticated user profile",
    "GET /enrollments - List enrollments",
    "POST /enrollments - Create enrollment",
    "POST /enrollments/full - Create enrollment with new student",
    "GET /enrollments/{id} - Get enrollment details",
    "PATCH /enrollments/{id} - Update enrollment",
    "DELETE /enrollments/{id} - Delete enrollment",
    "POST /enrollments/{id}/documents - Upload enrollment document",
    "GET /enrollments/{id}/documents/content - Download enrollment document",
    "GET /students - List students",
    "POST /students - Create student",
    "POST /students/bulk - Bulk upload students from CSV",
    "GET /students/{id} - Get student details",
    "PATCH /students/{id} - Update student",
    "GET /academic/subjects - List subjects",
    "POST /academic/subjects - Create subject",
    "GET /academic/grades - List grades",
    "POST /academic/grades - Record grade",
    "GET /academic/attendance - List attendance records",
    "POST /academic/attendance - Record attendance",
    "GET /discipline/cases - List discipline cases",
    "POST /discipline/cases - Create discipline case",
    "POST /discipline/cases/{id}/events - Add event to case",
    "GET /communications/circulars - List circulars",
    "POST /communications/circulars - Create circular",
    "GET /schools - List schools (superadmin)",
    "POST /schools - Create school (superadmin)",
    "GET /schools/{id}/settings - Get school settings",
    "PUT /schools/{id}/settings - Update school settings"
  ]
}
